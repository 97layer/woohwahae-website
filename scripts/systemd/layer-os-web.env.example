NODE_ENV=production
HOSTNAME=127.0.0.1
PORT=3081
LAYER_OS_BASE_URL=http://127.0.0.1:17808
LAYER_OS_LOCAL_ADMIN_BOOTSTRAP=false
SESSION_HMAC_SECRET=replace-me-with-32-byte-secret
LAYER_OS_WRITE_TOKEN=
# Prefer the SHA256 form so the VM never stores the plain admin password.
LAYER_OS_ADMIN_PASSWORD_SHA256=
