# Canonical Layer OS daemon environment for the Linux continuity host.
LAYER_OS_REPO_ROOT=/srv/layer-os/current
LAYER_OS_ADDR=127.0.0.1:17808
LAYER_OS_DATA_DIR=/var/lib/layer-os
LAYER_OS_PROVIDER_ENV_FILE=/etc/layer-os/providers.env
LAYER_OS_GATEWAY_ADAPTER=gemini
# Keep the always-on VM in observe mode by default.
LAYER_OS_ARCHITECT_AUTODISPATCH=false
LAYER_OS_ARCHITECT_AUTOVERIFY=false
LAYER_OS_ARCHITECT_GEMINI_RECOVERY=true
LAYER_OS_ARCHITECT_GEMINI_CLEANUP=true
LAYER_OS_ARCHITECT_CORPUS_RECOVERY=true
LAYER_OS_ARCHITECT_CORPUS_CLEANUP=true
GOCACHE=/var/lib/layer-os/gocache
GOMODCACHE=/var/lib/layer-os/gomodcache
