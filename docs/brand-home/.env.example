# Optional in local development. If omitted outside production, a local dev secret is used.
SESSION_HMAC_SECRET=replace-with-a-long-random-secret

# Layer OS daemon base URL for server-side BFF calls.
LAYER_OS_BASE_URL=http://127.0.0.1:17808

# Optional founder write token for protected admin mutations.
LAYER_OS_WRITE_TOKEN=

# Optional: disable one-click localhost bootstrap by setting false.
LAYER_OS_LOCAL_ADMIN_BOOTSTRAP=true
