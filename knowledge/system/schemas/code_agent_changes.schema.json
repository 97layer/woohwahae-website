{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code Agent Change Set",
  "type": "object",
  "required": ["files", "summary"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "old_content", "new_content"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "old_content": {
            "type": "string"
          },
          "new_content": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
