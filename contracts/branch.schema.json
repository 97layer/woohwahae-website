{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "layer-os/contracts/branch.schema.json",
  "title": "Branch",
  "type": "object",
  "required": [
    "branch_id",
    "root_branch_id",
    "title",
    "intent",
    "summary",
    "stage",
    "surface",
    "status",
    "notes",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "branch_id": { "type": "string" },
    "parent_branch_id": { "type": "string" },
    "root_branch_id": { "type": "string" },
    "title": { "type": "string" },
    "intent": { "type": "string" },
    "summary": { "type": "string" },
    "stage": { "type": "string" },
    "surface": { "type": "string" },
    "status": { "type": "string" },
    "basis_ref": { "type": "string" },
    "merge_target_branch_id": { "type": "string" },
    "merged_at": { "type": "string", "format": "date-time" },
    "notes": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
