{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "layer-os/contracts/execute_run.schema.json",
  "title": "ExecuteRun",
  "type": "object",
  "required": [
    "execute_id",
    "work_item_id",
    "policy_decision_id",
    "mode",
    "status",
    "notes",
    "started_at"
  ],
  "properties": {
    "execute_id": { "type": "string" },
    "work_item_id": { "type": "string" },
    "policy_decision_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["local", "single", "blocked"] },
    "status": { "type": "string", "enum": ["recorded", "succeeded", "failed"] },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false
}
