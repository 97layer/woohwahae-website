{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "layer-os/contracts/session_bootstrap_packet.schema.json",
  "title": "SessionBootstrapPacket",
  "type": "object",
  "required": [
    "generated_at",
    "source",
    "read_only",
    "degraded",
    "knowledge"
  ],
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "read_only": {
      "type": "boolean"
    },
    "degraded": {
      "type": "boolean"
    },
    "tooling": {
      "$ref": "#/$defs/tooling_health"
    },
    "knowledge": {
      "$ref": "knowledge_packet.schema.json"
    },
    "prompting": {
      "$ref": "#/$defs/prompting_contract"
    },
    "continuity": {
      "$ref": "#/$defs/continuity_view"
    },
    "resume": {
      "$ref": "#/$defs/session_checkpoint"
    },
    "handoff": {
      "$ref": "handoff_packet.schema.json"
    },
    "review_room": {
      "$ref": "review_room_summary.schema.json"
    },
    "capabilities": {
      "$ref": "capability_registry.schema.json"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "prompting_contract": {
      "type": "object",
      "required": [
        "directive",
        "cognition_mode",
        "decision_scope",
        "autonomy_budget",
        "mutation_policy",
        "escalation_triggers",
        "open_questions"
      ],
      "properties": {
        "directive": { "type": "string" },
        "cognition_mode": { "type": "string", "enum": ["staff_advisor", "executor"] },
        "decision_scope": { "type": "string", "enum": ["bounded", "full"] },
        "autonomy_budget": { "type": "string", "enum": ["manual_only", "single_step", "multi_step"] },
        "mutation_policy": { "type": "string", "enum": ["read_only", "scoped_write", "full_write"] },
        "escalation_triggers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "tooling_health": {
      "type": "object",
      "required": [
        "status",
        "required_mcp_ready",
        "missing_required"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "required_mcp_ready": {
          "type": "boolean"
        },
        "session_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "missing_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "continuity_note": {
      "type": "object",
      "required": [
        "note_id",
        "kind",
        "text",
        "refs",
        "created_at"
      ],
      "properties": {
        "note_id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "note",
            "todo",
            "decision",
            "risk"
          ]
        },
        "text": {
          "type": "string"
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "continuity_record": {
      "type": "object",
      "required": [
        "record_id",
        "source",
        "actor",
        "status",
        "current_focus",
        "next_steps",
        "open_risks",
        "refs",
        "notes",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "record_id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "resolved",
            "stale"
          ]
        },
        "current_focus": {
          "type": "string"
        },
        "current_goal": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoff_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/continuity_note"
          }
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolved_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "continuity_suggestion": {
      "type": "object",
      "required": [
        "suggestion_id",
        "kind",
        "summary",
        "source"
      ],
      "properties": {
        "suggestion_id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "risk",
            "todo",
            "route",
            "thread"
          ]
        },
        "summary": {
          "type": "string"
        },
        "ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "continuity_view": {
      "type": "object",
      "required": [
        "related_threads",
        "suggestions"
      ],
      "properties": {
        "record": {
          "$ref": "#/$defs/continuity_record"
        },
        "related_threads": {
          "type": "array",
          "items": {
            "$ref": "open_thread.schema.json"
          }
        },
        "suggestions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/continuity_suggestion"
          }
        }
      },
      "additionalProperties": false
    },
    "session_checkpoint": {
      "type": "object",
      "required": [
        "checkpoint_id",
        "source",
        "actor",
        "current_focus",
        "next_steps",
        "open_risks",
        "refs",
        "updated_at"
      ],
      "properties": {
        "checkpoint_id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "actor": {
          "type": "string"
        },
        "current_focus": {
          "type": "string"
        },
        "current_goal": {
          "type": [
            "string",
            "null"
          ]
        },
        "next_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "handoff_note": {
          "type": [
            "string",
            "null"
          ]
        },
        "note": {
          "type": [
            "string",
            "null"
          ]
        },
        "refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
