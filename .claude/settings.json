{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/plan-council.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/proactive-advisor.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/progress-snapshot.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/command-guard.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-path.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/code-quality-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/deepwork-tracker.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/code-quality-check.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/deepwork-tracker.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/browser-reload.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/output-secret-filter.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/gemini-critic.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-stop.sh"
          }
        ]
      }
    ]
  }
}
